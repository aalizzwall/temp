# =============================================================================
# 📚 護理師國考教材專案 - Git Ignore 規則
# 目標：保持 repository 乾淨，只包含純淨教材內容（.md、.txt）
# =============================================================================
# =============================================================================
# 🔧 Python 腳本與過程產出（應留在 .gitignore 中）
# =============================================================================

# ❌ Python 腳本（非教材內容，留在 process/ 目錄中）
process/*.py
process/*.bak
process/*.new
process/*.tmp
course_mapping/*.py
exams/*.py
scripts/*.py

# ❌ JSON 中間數據（過程產出）
all_nursing_questions.json
classified_nursing.json
extract_pharm_mapped.json
course_mapping.json
pharm_mapped.json
progress.json

# ❌ 備份檔案（開發過程產出）
*.bak
*.tmp
*.new
*.swp

# =============================================================================
# 📚 應該保留在 repository 的內容
# =============================================================================
# ✅ Markdown 教材
textbooks/*.md
archived/*.md

# ✅ 原始考題檔案（.txt 純文本格式）
exams/*.txt

# ✅ 專案說明文件
README.md
master_outline.md

# ✅ 圖片資源
images/

# =============================================================================
# 📊 版本控制建議
# =============================================================================
# - Markdown 教材應使用 Git 進行版本控制
# - Python 腳本可用於開發過程，但不需要放入 Git
# - JSON 中間數據應保留在本地 process/ 目錄中
# =============================================================================
